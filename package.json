{
  "name": "caja-lumina",
  "version": "1.0.3",
  "type": "module",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm exec tsx server/index.ts",
    "build:app": "vite build && esbuild server/index.ts --platform=node --bundle --format=cjs --outfile=dist/index.cjs --alias:@shared=./shared --external:better-sqlite3 --external:vite --external:lightningcss --external:esbuild --external:@replit/vite-plugin-cartographer --external:@replit/vite-plugin-dev-banner --external:@replit/vite-plugin-runtime-error-modal",
    "build": "pnpm run build:app && pnpm exec rimraf release && pnpm exec electron-rebuild -f -w better-sqlite3 && electron-builder && pnpm rebuild better-sqlite3",
    "pack": "electron-builder --dir",
    "start": "concurrently \"cross-env NODE_ENV=development pnpm exec tsx server/index.ts\" \"wait-on http://localhost:5000 && electron .\"",
    "start:web": "cross-env NODE_ENV=development pnpm exec tsx server/index.ts",
    "start:prod": "cross-env NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push"
  },
  "build": {
    "appId": "com.cajalumina.app",
    "productName": "Caja Lumina",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/prebuild-install/**/*",
      "node_modules/node-abi/**/*",
      "node_modules/napi-build-utils/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "client/public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Caja Lumina"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "lucide-react": "^0.453.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.3.5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@replit/vite-plugin-cartographer": "^0.3.1",
    "@replit/vite-plugin-dev-banner": "^0.1.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@tailwindcss/typography": "^0.5.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.4",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.47",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vite": "^5.4.20",
    "wait-on": "^9.0.4"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
